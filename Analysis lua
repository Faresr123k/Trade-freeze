-- Find Trade Machines in the game
function findTradeMachines()
    local machines = {}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name:lower():find("trade") and obj:IsA("Model") then
            table.insert(machines, {
                object = obj,
                name = obj.Name,
                position = obj:GetPivot().Position
            })
        end
    end
    
    return machines
end

-- Analyze RemoteEvents for vulnerabilities
function analyzeRemoteEvents()
    local vulnerableEvents = {}
    
    for _, service in pairs({ReplicatedStorage, Workspace}) do
        for _, obj in pairs(service:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                if obj.Name:lower():find("trade") or obj.Name:lower():find("exchange") then
                    table.insert(vulnerableEvents, {
                        name = obj.Name,
                        fullName = obj:GetFullName(),
                        type = obj.ClassName,
                        parent = obj.Parent.Name
                    })
                end
            end
        end
    end
    
    return vulnerableEvents
end

