-- وظيفة تشفير بسيطة (XOR)
local function xorEncrypt(text, key)
    local result = ""
    for i = 1, #text do
        local byte = string.byte(text, i)
        local keyByte = string.byte(key, ((i - 1) % #key) + 1)
        result = result .. string.char(bit32.bxor(byte, keyByte))
    end
    return result
end

-- وظيفة فك تشفير
local function xorDecrypt(text, key)
    return xorEncrypt(text, key) -- XOR هو عملية متناظرة
end

-- وظيفة تحليل RemoteEvents
local function analyzeRemoteEvents()
    local results = {}
    local remoteEvents = {}
    
    -- البحث عن RemoteEvents في مساحات العمل المختلفة
    for _, service in ipairs({game:GetService("Workspace"), game:GetService("ReplicatedFirst"), game:GetService("ReplicatedStorage")}) do
        for _, obj in ipairs(service:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                table.insert(remoteEvents, {
                    Name = obj.Name,
                    Parent = obj.Parent:GetFullName(),
                    Type = obj.ClassName
                })
            end
        end
    end
    
    -- تحليل كل RemoteEvent للبحث عن ثغرات
    for _, remote in ipairs(remoteEvents) do
        local vulnerabilities = {}
        
        -- التحقق من عدم وجود حماية
        local parent = game:GetService("Workspace"):FindFirstChild(remote.Parent)
        if parent then
            local scripts = parent:FindFirstChildWhichIsA("Script", true)
            if scripts then
                local source = scripts.Source
                if not source:find("require") or not source:find("Validate") then
                    table.insert(vulnerabilities, "قد لا يحتوي على تحقق صحيح")
                end
            end
        end
        
        table.insert(results, {
            Remote = remote,
            Vulnerabilities = vulnerabilities
        })
    end
    
    return results
end

-- وظيفة تحليل Trades Machines
local function analyzeTradesMachines()
