-- Analyze Trade UI
function analyzeTradeUI(uiFrame)
    local tradeData = {}
    
    for _, child in pairs(uiFrame:GetDescendants()) do
        if child:IsA("TextBox") then
            table.insert(tradeData, {
                type = "input",
                name = child.Name,
                placeholder = child.PlaceholderText
            })
        elseif child:IsA("TextButton") and (child.Name:lower():find("trade") or child.Name:lower():find("confirm")) then
            table.insert(tradeData, {
                type = "button",
                name = child.Name,
                text = child.Text
            })
        end
    end
    
    if #tradeData > 0 then
        local message = "🔍 تحليل واجهة التداول:\n"
        for _, data in pairs(tradeData) do
            message = message .. "- " .. data.type .. ": " .. data.name .. "\n"
        end
        sendToTelegram(message)
    end
end

