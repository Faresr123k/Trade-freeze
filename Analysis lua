-- [ الخدمات الأساسية ]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

-- [ إعدادات المهمة ]
local Config = {
    AutoFarm = true,
    Desync = true,
    AntiKick = true, -- تفعيل منع الطرد
    DodgeRange = 15,
    Speed = math.random(45, 55), -- سرعة متغيرة لتبدو بشرية
    BaseLocation = Vector3.new(100, 10, 100), -- ضع إحداثيات قاعدتك هنا
    BrainrotAnchor = "BrainrotPartName" -- اسم الغرض المستهدف
}

-- ==========================================
-- [ 1. نظام Anti-Kick (المستوى المتقدم) ]
-- ==========================================
if Config.AntiKick then
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)

    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        -- إذا حاولت اللعبة استدعاء أمر Kick، السكربت سيقوم بإيقافه فوراً
        if tostring(method) == "Kick" or tostring(method) == "kick" then
            warn("🛡️ تم إحباط محاولة طرد من السيرفر!")
            return nil 
        end

        return oldNamecall(self, unpack(args))
    end)
    setreadonly(mt, true)
    print("✅ Anti-Kick System: ACTIVE")
end

-- ==========================================
-- [ 2. محرك الحركة والديسينك ]
-- ==========================================

-- نظام الديسينك (التلاعب بالـ Hitbox)
local function ApplyDesync()
    if Config.Desync then
        local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local oldV = root.Velocity
            -- سرعة وهمية مشتتة للسيرفر
            root.Velocity = Vector3.new(math.random(-200, 200), 0, math.random(-200, 200))
            RunService.RenderStepped:Wait()
            root.Velocity = oldV
        end
    end
end

-- الانتقال السلس (Tweening) مع تجنب الاكتشاف
local function SmartMoveTo(targetPos)
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local distance = (root.Position - targetPos).Magnitude
    local duration = distance / Config.Speed
    
    -- استخدام EasingStyle لجعل الحركة "طبيعية" (تسارع وتباطؤ)
    local info = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    local tween = TweenService:Create(root, info, {CFrame = CFrame.new(targetPos)})
    
    tween:Play()
    return tween
end

-- ==========================================
-- [ 3. دورة العمل: سرقة -> قاعدة ]
-- ==========================================

local function MissionLoop()
    while Config.AutoFarm do
        task.wait(1.5) -- انتظار بسيط بين الدورات لتقليل الضغط
        
        -- البحث عن الهدف (البراينروت)
        local target = workspace:FindFirstChild(Config.BrainrotAnchor, true)
        
        if target and target:IsA("BasePart") then
            print("🚀 مستهدف: " .. target.Name .. " | جاري التحرك...")
            
            -- الذهاب للهدف
            local move = SmartMoveTo(target.Position)
            if move then move.Completed:Wait() end
            
            task.wait(0.7) -- وقت لالتقاط الغرض
            
            -- العودة للقاعدة
            print("📦 تم الاستحواذ! العودة للقاعدة...")
            local back = SmartMoveTo(Config.BaseLocation)
            if back then back.Completed:Wait() end
            
            print("💰 تمت المهمة بنجاح.")
        else
            warn("🔍 لم يتم العثور على هدف، جاري إعادة الفحص...")
        end
    end
end

-- [ التشغيل النهائي ]
RunService.Heartbeat:Connect(ApplyDesync)
task.spawn(MissionLoop)

print("💎 Brainrot PRO Suite with Anti-Kick Loaded!")
