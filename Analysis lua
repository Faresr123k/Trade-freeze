    -- إنشاء رسالة النتائج
    local message = "تحليل Steal a Brainrot (مضاد للحظر):\n\n"
    message = message .. "RemoteEvents: " .. #results.RemoteEvents .. "\n"
    message = message .. "Trade Machines: " .. #results.TradeMachines .. "\n"
    message = message .. "Vulnerabilities: " .. #results.Vulnerabilities
    
    -- إنشاء سكربت تجميد التداول المخصص
    local tradeScript = createCustomTradeFreezeScript(results)
