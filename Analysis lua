-- Find Trade Machine
function findTradeMachine()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name:lower():find("trade") and obj:IsA("Model") then
            return obj
        end
    end
    return nil
end

-- Find Target Player
function findTargetPlayer()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Name:lower():find(TARGET_USERNAME:lower()) then
            return player
        end
    end
    return nil
end

