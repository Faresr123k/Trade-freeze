-- [ الخدمات ]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

-- [ إعدادات المنظومة ]
local Config = {
    AutoFarm = true,
    ReturnHeight = 35, -- ارتفاع شاهق لتجنب كل شيء
    Speed = 60,
    TargetName = "Brainrot",
    State = "Idle", -- Idle, Moving, Returning
    AntiAdmin = true -- توقف السكربت عند دخول مراقب
}

-- [ 1. نظام كشف المراقبين (Anti-Admin) ]
if Config.AntiAdmin then
    Players.PlayerAdded:Connect(function(plr)
        -- فحص الرتبة أو الشارات (Badges) إذا كان أدمن
        if plr:GetRankInGroup(0) > 200 or plr.AccountAge < 1 then 
            Config.AutoFarm = false
            print("🚨 Admin/Sus detected! Stopping script for safety.")
        end
    end)
end

-- [ 2. كاشف القاعدة الديناميكي (المطور) ]
local function GetMyBase()
    -- يبحث عن أي مكان يحمل اسمك أو اسم العرض الخاص بك
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") or v:IsA("BasePart") then
            if v.Name:find(Player.Name) or v.Name:find(Player.DisplayName) then
                -- التأكد أن الموقع ثابت وليس جزءاً من جسمك
                if not v:IsDescendantOf(Player.Character) then
                    return v.Position
                end
            end
        end
    end
    -- كحل أخير: مكان الرسبون
    return Player.RespawnLocation and Player.RespawnLocation.Position or Vector3.new(0,0,0)
end

-- [ 3. نظام الشبح (Noclip) ]
-- يجعل شخصيتك تمر عبر الجدران أثناء العودة
local function SetNoclip(state)
    for _, part in pairs(Player.Character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = not state
        end
    end
end

-- [ 4. محرك العودة "فوق السحاب" (Ghost Return) ]
local function UltimateReturn()
    if Config.State == "Returning" then return end
    Config.State = "Returning"
    
    local root = Player.Character:WaitForChild("HumanoidRootPart")
    local basePos = GetMyBase()
    
    -- تفعيل وضع الشبح
    SetNoclip(true)
    
    -- المرحلة أ: الارتفاع العمودي السريع
    local upPos = root.Position + Vector3.new(0, Config.ReturnHeight, 0)
    local t1 = TweenService:Create(root, TweenInfo.new(1.2, Enum.EasingStyle.Quart), {CFrame = CFrame.new(upPos)})
    t1:Play()
    t1.Completed:Wait()

    -- المرحلة ب: الطيران المباشر نحو القاعدة (فوق الجدران والفخاخ)
    local targetAir = Vector3.new(basePos.X, root.Position.Y, basePos.Z)
    local dist = (root.Position - targetAir).Magnitude
    local t2 = TweenService:Create(root, TweenInfo.new(dist/Config.Speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetAir)})
    t2:Play()
    t2.Completed:Wait()

    -- المرحلة ج: الهبوط الدقيق داخل القاعدة
    local t3 = TweenService:Create(root, TweenInfo.new(1.5, Enum.EasingStyle.Bounce), {CFrame = CFrame.new(basePos + Vector3.new(0, 3, 0))})
    t3:Play()
    t3.Completed:Wait()

    -- إلغاء وضع الشبح
    SetNoclip(false)
    Config.State = "Idle"
end

-- [ 5. المعالج الذكي للسرقة ]
task.spawn(function()
    while true do
        task.wait(0.5)
        if Config.AutoFarm and Config.State == "Idle" then
            -- البحث عن أقرب براينروت
            local target = nil
            local minDist = math.huge
            for _, v in pairs(workspace:GetDescendants()) do
                if v.Name:find(Config.TargetName) and v:IsA("BasePart") then
                    local d = (Player.Character.HumanoidRootPart.Position - v.Position).Magnitude
                    if d < minDist then
                        minDist = d
                        target = v
                    end
                end
            end

            if target and minDist < 500 then
                Config.State = "Moving"
                -- الذهاب للهدف
                local t = TweenService:Create(Player.Character.HumanoidRootPart, TweenInfo.new(minDist/Config.Speed, Enum.EasingStyle.Sine), {CFrame = CFrame.new(target.Position)})
                t:Play()
                t.Completed:Wait()
                
                -- الانتظار للتأكد من الحمل (ستتفعل UltimateReturn عبر ChildAdded)
                task.wait(1)
                if Config.State == "Moving" then Config.State = "Idle" end
            end
        end
    end
end)

-- [ 6. حساس الحمل الفوري ]
Player.Character.ChildAdded:Connect(function(child)
    -- إذا أمسكت البراينروت بأي طريقة، ابدأ العودة فوراً
    if child.Name:find("Brainrot") or child:IsA("Tool") then
        task.wait(0.1)
        UltimateReturn()
    end
end)

print("🛡️ منظومة السيطرة الشاملة مفعمة بالعمل. وضع الشبح: جاهز.")
