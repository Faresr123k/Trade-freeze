-- [ الخدمات ]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

-- [ إعدادات السيطرة ]
local Config = {
    SafeHeight = 15, -- الارتفاع عن الأرض عند العودة (البساط الوهمي)
    ReturnSpeed = 55,
    AntiBan = true,
    DestroyTraps = true,
    DodgeDistance = 20,
    BasePos = Vector3.new(100, 10, 100) -- ضع إحداثيات قاعدتك هنا
}

-- ==========================================
-- [ 1. درع الحماية المتطور (Anti-Ban & Kick) ]
-- ==========================================
if Config.AntiBan then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local old = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        -- منع الطرد ومنع إرسال تقارير السرعة للسيرفر
        if method == "Kick" or method == "kick" or method == "BreakJoints" then 
            return nil 
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
end

-- ==========================================
-- [ 2. نظام تدمير آليات الأعداء والأفخاخ ]
-- ==========================================
local function NeutralizeTraps()
    if not Config.DestroyTraps then return end
    for _, v in pairs(workspace:GetDescendants()) do
        -- تدمير أي فخ أو آلة تعيق الحركة (بناءً على الأسماء الشائعة)
        if v:IsA("TouchTransmitter") and (v.Parent.Name:find("Trap") or v.Parent.Name:find("Machine")) then
            v:Destroy() -- حذف خاصية اللمس القاتل
        end
    end
end
task.spawn(NeutralizeTraps)

-- ==========================================
-- [ 3. محرك الارتفاع والعودة الآمنة (Hover Carpet) ]
-- ==========================================
local function HoverReturn()
    local character = Player.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- إنشاء قوة رفع تمنع الجاذبية وتجعلك كأنك على بساط
    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.MaxForce = Vector3.new(0, math.huge, 0)
    bodyVelocity.Parent = root

    -- الارتفاع والتحرك للقاعدة
    local targetWithHeight = Config.BasePos + Vector3.new(0, Config.SafeHeight, 0)
    local dist = (root.Position - targetWithHeight).Magnitude
    
    local tween = TweenService:Create(root, TweenInfo.new(dist/Config.ReturnSpeed, Enum.EasingStyle.Quad), {
        CFrame = CFrame.new(targetWithHeight)
    })
    
    tween:Play()
    tween.Completed:Connect(function()
        bodyVelocity:Destroy() -- العودة للجاذبية عند الوصول
    end)
end

-- ==========================================
-- [ 4. نظام التفادي القتالي أثناء الحمل ]
-- ==========================================
RunService.Heartbeat:Connect(function()
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- التحقق من وجود أعداء قريبين للهرب منهم
    for _, enemy in pairs(Players:GetPlayers()) do
        if enemy ~= Player and enemy.Character and enemy.Character:FindFirstChild("HumanoidRootPart") then
            local enemyRoot = enemy.Character.HumanoidRootPart
            local distance = (root.Position - enemyRoot.Position).Magnitude
            
            if distance < Config.DodgeRange then
                -- تفادي ذكي: التحرك بعيداً عن العدو في الاتجاه المعاكس
                local direction = (root.Position - enemyRoot.Position).Unit
                root.CFrame = root.CFrame + (direction * 2) -- إزاحة صغيرة سريعة
            end
        end
    end
end)

-- [ تشغيل تلقائي عند حمل الـ Brainrot ]
-- سنفترض أن اللعبة تضع أداة (Tool) في يدك عند الحمل
Player.Character.ChildAdded:Connect(function(child)
    if child:IsA("Tool") or child.Name:find("Brainrot") then
        print("Brainrot Detected! Activating Safe Return...")
        task.wait(0.2)
        HoverReturn()
    end
end)

print("💎 Anti-Ban Master Suite Loaded!")
