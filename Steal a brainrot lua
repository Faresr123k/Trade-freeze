-- [ الخدمات ]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player = Players.LocalPlayer

-- [ الإعدادات الاحترافية ]
local Config = {
    AutoSteal = true,
    GhostMode = true, -- ميزة الديسينك (الجلتش)
    AntiKick = true,
    Speed = 52,
    BaseLocation = Vector3.new(0, 0, 0), -- غيرها بإحداثيات قاعدتك
    TargetName = "Brainrot" -- اسم الغرض في اللعبة
}

-- [ 1. نظام الحماية الشاملة (Anti-Kick) ]
if Config.AntiKick then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local old = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Kick" or method == "kick" then return nil end
        return old(self, ...)
    end)
    setreadonly(mt, true)
end

-- [ 2. ميزة الديسينك المتقدمة (تظهرك كجليتش للآخرين) ]
-- [00:00:49] كما في الفيديو: تجعل الخصم يضرب الهواء
RunService.Heartbeat:Connect(function()
    if Config.GhostMode and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local root = Player.Character.HumanoidRootPart
        -- تزييف السرعة المتجهة للسيرفر (Desync)
        local rawVelocity = root.Velocity
        root.Velocity = Vector3.new(math.random(-300, 300), -100, math.random(-300, 300))
        RunService.RenderStepped:Wait()
        root.Velocity = rawVelocity
    end
end)

-- [ 3. محرك الحركة السلس (Tween Engine) ]
local function MoveTo(pos)
    local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local dist = (root.Position - pos).Magnitude
    local info = TweenInfo.new(dist/Config.Speed, Enum.EasingStyle.Sine)
    local tween = TweenService:Create(root, info, {CFrame = CFrame.new(pos)})
    tween:Play()
    return tween
end

-- [ 4. ميزة الـ Remote Steal (السرقة الذكية) ]
local function AttemptRemoteSteal(target)
    -- محاولة إرسال إشارة السرقة مباشرة للسيرفر (بدون الحاجة للمس دقيق)
    local events = game:GetService("ReplicatedStorage"):GetDescendants()
    for _, v in pairs(events) do
        if v:IsA("RemoteEvent") and (v.Name:lower():find("steal") or v.Name:lower():find("collect")) then
            v:FireServer(target)
        end
    end
end

-- [ 5. الحلقة المركزية (العمل التلقائي) ]
task.spawn(function()
    while Config.AutoSteal do
        task.wait(1)
        -- البحث عن أقرب هدف
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj.Name:find(Config.TargetName) and obj:IsA("BasePart") then
                -- الانتقال لمكان الهدف
                local m = MoveTo(obj.Position + Vector3.new(0, 2, 0))
                if m then m.Completed:Wait() end
                
                -- تنفيذ السرقة (فيزيائياً وعن بعد)
                AttemptRemoteSteal(obj)
                task.wait(0.5)
                
                -- العودة للقاعدة
                local b = MoveTo(Config.BaseLocation)
                if b then b.Completed:Wait() end
                break
            end
        end
    end
end)
