local statusLabel = Instance.new("TextLabel", mainFrame)
statusLabel.Size = UDim2.new(1, -20, 0, 25)
statusLabel.Position = UDim2.new(0, 10, 0, 55)
statusLabel.Text = "Status: Scanning..."
statusLabel.TextColor3 = Color3.new(0, 1, 0)
statusLabel.Font = Enum.Font.SourceSans
statusLabel.TextSize = 14
statusLabel.BackgroundTransparency = 1

local priorityLabel = Instance.new("TextLabel", mainFrame)
priorityLabel.Size = UDim2.new(1, -20, 0, 25)
priorityLabel.Position = UDim2.new(0, 10, 0, 85)
priorityLabel.Text = "Priority Targets: 0"
priorityLabel.TextColor3 = Color3.new(1, 1, 0)
priorityLabel.Font = Enum.Font.SourceSans
priorityLabel.TextSize = 14
priorityLabel.BackgroundTransparency = 1

local toggleButton = Instance.new("TextButton", mainFrame)
toggleButton.Size = UDim2.new(0, 100, 0, 30)
toggleButton.Position = UDim2.new(0, 10, 0, 115)
toggleButton.Text = "Disable"
toggleButton.TextColor3 = Color3.new(1, 1, 1)
toggleButton.BackgroundColor3 = Color3.new(0, 0.7, 0)
toggleButton.Font = Enum.Font.SourceSans
toggleButton.TextSize = 14

-- دالة لتحديث الواجهة الرسومية
local function updateGUI(status, priorityCount)
    if Config.Enabled then
        statusLabel.Text = "Status: " .. status
        statusLabel.TextColor3 = Color3.new(0, 1, 0)
        toggleButton.Text = "Disable"
        toggleButton.BackgroundColor3 = Color3.new(0, 0.7, 0)
    else
        statusLabel.Text = "Status: Inactive"
        statusLabel.TextColor3 = Color3.new(1, 0, 0)
        toggleButton.Text = "Enable"
        toggleButton.BackgroundColor3 = Color3.new(0.7, 0, 0)
    end
    
    priorityLabel.Text = "Priority Targets: " .. tostring(priorityCount)
end

-- وظيفة زر التبديل
toggleButton.MouseButton1Click:Connect(function()
    Config.Enabled = not Config.Enabled
    updateGUI("Toggled", 0)
end)

-- تحديث الواجهة بشكل دوري
spawn(function()
    while true do
        if Config.Enabled then
            updateGUI("Scanning...", #priorityTargets)
        else
            updateGUI("Inactive", 0)
        end
        task.wait(1)
    end
end)

-- تحديث الواجهة عند بدء التشغيل
updateGUI("Loaded", 0)

print("💰 Brainrot Money Hunter Loaded Successfully!")
print("🎯 Script is now active. Use the GUI to control it.")

-- نهاية السكربت
]])
