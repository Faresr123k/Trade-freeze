}

-- دالة التحقق
function isTargetBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    local lower = string.lower(itemName)
    for _, b in pairs(TargetBrainrots) do
        if string.lower(b) == lower then return true end
    end
    return false
end

function isPriorityMoneyBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    local lower = string.lower(itemName)
    for _, b in pairs(PriorityMoneyBrainrots) do
        if string.lower(b) == lower then return true end
    end
    return false
end

-- متغير عام للـ GUI (مُصلح)
local PriorityCount = 0

-- دالة الترايد
function executeTrade(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    local tradeEvents = {"TradeEvent", "RemoteTrade", "SendTrade", "RequestTrade", "AcceptTrade", "TradeRequest", "TradeSystem", "Trading", "Trade", "TradeRemote"}
    for _, name in pairs(tradeEvents) do
        local event = ReplicatedStorage:FindFirstChild(name, true)
        if event and event:IsA("RemoteEvent") then
            pcall(function()
                event:FireServer(targetPlayer)
                if Config.DebugMode then print("💰 Trade sent to: " .. targetPlayer.Name) end
            end)
            return true
        end
    end
    return false
end

-- دالة المسح
function scanPlayerForBrainrots(player)
    if not player or not player.Character then return nil end
    local foundItem, isPriority = nil, false

    if player.Backpack then
        for _, item in pairs(player.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                foundItem = item.Name
                isPriority = isPriorityMoneyBrainrot(item.Name)
                break
            end
        end
    end
    if not foundItem and player.Character then
        for _, item in pairs(player.Character:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                foundItem = item.Name
                isPriority = isPriorityMoneyBrainrot(item.Name)
                break
            end
        end
    end
    return foundItem and {item = foundItem, isPriority = isPriority, player = player}
end

-- الحلقة الرئيسية
RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    local currentTime = tick()
    if currentTime - (lastScanTime or 0) < Config.ScanInterval then return end
    lastScanTime = currentTime

    local myRoot = LocalPlayer.Character.HumanoidRootPart
    local allTargets, priorityTargets = {}, {}

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (myRoot.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if dist <= Config.MaxDistance then
                local result = scanPlayerForBrainrots(player)
                if result then
                    if result.isPriority then
                        table.insert(priorityTargets, result)
                    else
                        table.insert(allTargets, result)
                    end
                end
            end
        end
    end

    PriorityCount = #priorityTargets  -- ← تم التصليح هنا

    local targets = #priorityTargets > 0 and priorityTargets or allTargets
    for _, t in pairs(targets) do
        if executeTrade(t.player) then
            task.wait(0.2)
            break
        end
    end
end)

