-- 🎯 بسيط، سريع، وفعال

load([[
-- الخدمات الأساسية
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- 🔥 إعدادات السكربت
local Config = {
    Enabled = true,
    ScanInterval = 0.5, -- سرعة المسح (أسرع = أفضل)
    MaxDistance = 100, -- مسافة البحث عن اللاعبين
    DebugMode = true, -- لإظهار رسائل التنقيح
}

-- 🧠 قائمة الـ Brainrots الأساسية (سيتم البحث عن هذه الأسماء)
local TargetBrainrots = {
    "Festive 67", "Esok Sekolah", "Bacuru and Egguru", "Headless Horseman",
    "noo my gold", "snailo colvero", "Dragon Cannelloni", "Gold Gold Gold",
    "la lucky grande", "lavadorito spinito", "los candies", "burgeru and fryuro",
    "la Extinct grande", "los primos", "los bros", "las sis", "meowl", "Cerberus",
    "garama and madundung", "Money Money Puggy", "Ketupat Kepat", "Tang Tang Keletang",
    "Hydra dragon cannelloni", "Los sekolah", "Spaghetti Tualetti", "Los mobilis",
    "Lovin rose", "Nacho Spyder", "Nuclearo dinossauro", "La casa boo", "Orcaledon",
    "Evildon", "TicTac Sahur", "Swaggy Bros", "W or L", "Cooki and Milki",
    "capitano moby", "La Supreme Combinasion", "La jolly grande", "Ketchuru and Musturu",
    "La Taco Combinasion", "La Romantic grande", "La ginger Sekolah", "Swag Soda",
    "Tralaledon", "Gobblino Uniciclino", "La Spooky Grande", "Tuff Toucan",
    "Popcuro and Fizzuru", "Strawberry Elephant"
}

-- 💰 قائمة الـ Brainrots النقديّة ذات الأولوية القصوى (تنتج 100m/s أو أكثر)
local PriorityMoneyBrainrots = {
    "Money Money Puggy", -- غالباً ما يكون الأكثر ربحية
    "Gold Gold Gold",
    "noo my gold",
    "la lucky grande",
    "lavadorito spinito",
    "Dragon Cannelloni", -- أحياناً يكون نقدياً
    "Hydra Dragon", -- أحياناً يكون نقدياً
    -- يمكنك إضافة أي أسماء أخرى تعرف أنها تنتج مالاً بكثرة هنا
}

-- 🎯 دالة للتحقق إذا كان الاسم هو brainrot مستهدف
function isTargetBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    
    local lowerItemName = string.lower(itemName)
    
    for _, brainrot in pairs(TargetBrainrots) do
        if string.lower(brainrot) == lowerItemName then
            return true
        end
    end
    
    return false
end

-- 💰 دالة للتحقق إذا كان الـ brainrot نقدياً (أولوية قصوى)
function isPriorityMoneyBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    
    local lowerItemName = string.lower(itemName)
    
    for _, moneyBrainrot in pairs(PriorityMoneyBrainrots) do
        if string.lower(moneyBrainrot) == lowerItemName then
            return true
        end
    end
    
    return false
end

-- 🚀 دالة لتنفيذ الترايده (مبسطة ومحسّنة)
function executeTrade(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    -- قائمة RemoteEvents الشائعة للترايده
    local tradeEvents = {
        "TradeEvent", "RemoteTrade", "SendTrade", "RequestTrade", "AcceptTrade",
        "TradeRequest", "TradeSystem", "Trading", "Trade", "TradeRemote"
    }
    
    for _, eventName in pairs(tradeEvents) do
        local event = ReplicatedStorage:FindFirstChild(eventName, true)
        if event and event:IsA("RemoteEvent") then
            pcall(function()
                event:FireServer(targetPlayer)
                if Config.DebugMode then
                    print("💰 Trade attempt sent to: " .. targetPlayer.Name)
                end
                return true
            end)
        end
    end
    
    return false
end

-- 🔍 دالة لمسح لاعب واحد بحثاً عن brainrots
function scanPlayerForBrainrots(player)
    if not player or not player.Character then return nil end
    
    local foundItem = nil
    local isPriority = false
    
    -- البحث في حقيبة اللاعب أولاً (الأهم)
    if player.Backpack then
        for _, item in pairs(player.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                foundItem = item.Name
                isPriority = isPriorityMoneyBrainrot(item.Name)
                if Config.DebugMode then
                    local priority = isPriority and "💰 PRIORITY" or "🧠 TARGET"
                    print(priority .. " Found: " .. item.Name .. " in " .. player.Name .. "'s backpack")
                end
                break
            end
        end
    end
    
    -- إذا لم يتم العثور في الحقيبة، ابحث في الشخصية
    if not foundItem and player.Character then
        for _, item in pairs(player.Character:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                foundItem = item.Name
                isPriority = isPriorityMoneyBrainrot(item.Name)
                if Config.DebugMode then
                    local priority = isPriority and "💰 PRIORITY" or "🧠 TARGET"
                    print(priority .. " Found: " .. item.Name .. " on " .. player.Name .. "'s character")
                end
                break
            end
        end
    end
    
    return {item = foundItem, isPriority = isPriority, player = player}
end

-- 🚀 الحلقة الرئيسية للسكربت
local lastScanTime = 0

RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    
    -- التحكم في سرعة المسح
    local currentTime = tick()
    if currentTime - lastScanTime < Config.ScanInterval then
        return
    end
    lastScanTime = currentTime
    
    local myRootPart = LocalPlayer.Character.HumanoidRootPart
    local allTargets = {}
    local priorityTargets = {}
    
    -- مسح جميع اللاعبين القريبين
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (myRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if distance <= Config.MaxDistance then
                local result = scanPlayerForBrainrots(player)
                if result and result.item then
                    if result.isPriority then
                        table.insert(priorityTargets, result)
                    else
                        table.insert(allTargets, result)
                    end
                end
            end
        end
    end
    
    -- تنفيذ الترايده على الأهداف ذات الأولوية أولاً
    local targetsToProcess = #priorityTargets > 0 and priorityTargets or allTargets
    
    for _, target in pairs(targetsToProcess) do
        if executeTrade(target.player) then
            -- الانتظار قليلاً قبل محاولة الترايده التالية
            task.wait(0.2)
            break -- توقف بعد أول محاولة ناجحة لتجنب الحظر
        end
    end
end)

-- ✅ واجهة رسومية بسيطة     ← التعديل هنا ↓
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
screenGui.Name = "BrainrotHunterGUI"
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Size = UDim2.new(0, 250, 0, 150)
mainFrame.Position = UDim2.new(0, 50, 0, 50)
mainFrame.BackgroundColor3 = Color3.new(0.05, 0.05, 0.05)
mainFrame.BorderSizePixel = 2
mainFrame.BorderColor3 = Color3.new(1, 0.5, 0) -- لون برتقالي للدلالة على النقود
mainFrame.Active = true
mainFrame.Draggable = true

local title = Instance.new("TextLabel", mainFrame)
title.Size = UDim2.new(1, 0, 0, 35)
title.Position = UDim2.new(0, 0, 0, 10)
title.Text = "💰 Brainrot Hunter"
title.TextColor3 = Color3.new(1, 0.5, 0)
title.Font = Enum.Font.SourceSansBold
title.TextSize = 18
