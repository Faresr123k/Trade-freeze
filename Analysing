    for _, obj in pairs(LocalPlayer:WaitForChild("PlayerGui"):GetDescendants()) do
        if obj:IsA("Frame") or obj:IsA("ScreenGui") then
            local name = obj.Name:lower()
            if string.find(name, "trade") or string.find(name, "exchange") or 
               string.find(name, "offer") or string.find(name, "deal") then
                table.insert(analysisResults.gameStructure, {
                    type = "GUI",
                    name = obj.Name,
                    parent = obj.Parent.Name,
                    element = obj
                })
                addToOutput("🖼️ Trade GUI found: " .. obj.Name)
            end
        end
    end
    
    -- Find workspace trade elements
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Part") then
            local name = obj.Name:lower()
            if string.find(name, "trade") or string.find(name, "exchange") then
                table.insert(analysisResults.gameStructure, {
                    type = "Workspace",
                    name = obj.Name,
                    parent = obj.Parent.Name,
                    element = obj
