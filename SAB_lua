local VisualScript = {}

function VisualScript:FindTradeWindow()
    -- البحث عن نافذة الترايد
    for _, obj in ipairs(game.Players.LocalPlayer.PlayerGui:GetChildren()) do
        if obj.Name:find("Trade") or obj.Name:find("Trading") then
            return obj
        end
    end
    return nil
end

function VisualScript:GetItemSlots(tradeWindow)
    -- الحصول على خانات العناصر
    local slots = {}
    for _, slot in ipairs(tradeWindow:GetDescendants()) do
        if slot.Name:find("Slot") or slot.Name:find("Item") then
            table.insert(slots, slot)
        end
    end
    return slots
end

function VisualScript:CreateFakeLayer(originalSlot)
    -- إنشاء طبقة وهمية
    local fakeLayer = Instance.new("Frame")
    fakeLayer.Size = originalSlot.Size
    fakeLayer.Position = originalSlot.Position
    fakeLayer.BackgroundTransparency = 1
    fakeLayer.ZIndex = 10
    fakeLayer.Parent = originalSlot.Parent
    
    -- إضافة صورة مزيفة
    local fakeImage = Instance.new("ImageLabel")
    fakeImage.Size = UDim2.new(1, 0, 1, 0)
    fakeImage.Position = UDim2.new(0, 0, 0, 0)
    fakeImage.BackgroundTransparency = 1
    fakeImage.Image = "rbxassetid://123456789" -- أيدي صورة مزيفة
    fakeImage.Parent = fakeLayer
    
    return fakeLayer
end

function VisualScript:ApplyVisualDeception()
    local tradeWindow = self:FindTradeWindow()
    if not tradeWindow then return end
    
    local slots = self:GetItemSlots(tradeWindow)
    if #slots == 0 then return end
    
    -- اختيار أول خانة للتلاعب
    local targetSlot = slots[1]
    
    -- إنشاء الطبقة الوهمية
    local fakeLayer = self:CreateFakeLayer(targetSlot)
    
    -- إخفاء العنصر الأصلي
    targetSlot.Visible = false
    
    -- عرض العنصر المزيف
    fakeLayer.Visible = true
    
    -- تثبيت العرض
    game:GetService("RunService").Heartbeat:Connect(function()
        if fakeLayer and fakeLayer.Parent then
            -- الحفاظ على الوهم
            fakeLayer.ZIndex = 10
        end
    end)
end

function VisualScript:MonitorTradeState()
    -- مراقبة حالة الترايد
    while Config.Enabled do
        local tradeWindow = self:FindTradeWindow()
        if tradeWindow then
            -- التحقق من وجود عداد أو زر قبول
            local acceptButton = tradeWindow:FindFirstChild("Accept")
            local countdown = tradeWindow:FindFirstChild("Countdown")
            
            if acceptButton or countdown then
                -- تطبيق الخداع البصري
                self:ApplyVisualDeception()
                break
            end
        end
        wait(0.5)
    end
end

-- تشغيل السكربت
function VisualScript:Start()
    if Config.DebugMode then
        print("[Brainrot Visual] Script Started")
        print("[Brainrot Visual] Target: " .. Config.TargetItem)
        print("[Brainrot Visual] Multiplier: " .. Config.FakeMultiplier)
    end
    
    -- بدء المراقبة
    self:MonitorTradeState()
end

