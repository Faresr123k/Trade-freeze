local function startScript()
    log("Trade Visual Script v2 Loaded.") -- تم التعديل
    createUI()
    monitorForTrade()
end

local function setupToggle()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local ui = playerGui:WaitForChild("TradeVisualUI") -- تم التعديل
    local mainFrame = ui:WaitForChild("MainFrame")
    
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Config.Enabled = not Config.Enabled
            local statusLabel = mainFrame:WaitForChild("StatusLabel")
            
            if Config.Enabled then
                statusLabel.Text = "Status: Monitoring..."
                statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                log("Script Re-enabled. Restarting monitor.")
                monitorForTrade()
            else
                statusLabel.Text = "Status: Disabled"
                statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                log("Script Disabled by user.")
            end
        end
    end)
end

local function finalize()
    setupToggle()
    warn("[Trade Visual]: Script is fully active. Click the UI to toggle on/off.") -- تم التعديل
    warn("[Trade Visual]: Waiting for trade window to appear...") -- تم التعديل
end

startScript()
finalize()
