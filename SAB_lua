-- إعدادات السكربت
local Config = {
    Enabled = true,
    DebugMode = true, -- شغلها عشان تشوف الأخطاء
    TargetItemName = "Strawberry Elephant", -- تم التعديل
    FakeMultiplierText = "×10 Rainbow",
    FakeImageId = "rbxassetid://248295212434663" -- تم التعديل برقم Strawberry Elephant
}

-- خدمات Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- وظائف مساعدة
local function log(message)
    if Config.DebugMode then
        warn("[Visual Enhancement]: " .. message)
    end
end

local function findTradeUI()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    
    for _, gui in ipairs(playerGui:GetChildren()) do
        if gui:IsA("ScreenGui") or gui:IsA("Frame") or gui:IsA("LayerCollector") then
            if gui.Name:lower():find("trade") or gui.Name:lower():find("swap") or gui.Name:lower():find("exchange") then
                log("Found potential trade UI: " .. gui.Name)
                return gui
            end
            for _, child in ipairs(gui:GetDescendants()) do
                if child.Name:lower():find("trade") or child.Name:lower():find("swap") then
                    log("Found potential trade UI (descendant): " .. child:GetFullName())
                    return child.Parent
                end
            end
        end
    end
    
    for _, frame in ipairs(playerGui:GetDescendants()) do
        if frame:IsA("Frame") and frame.Size == UDim2.new(1, 0, 1, 0) and frame.Name ~= "TopBar" then
            local hasAcceptButton = frame:FindFirstChild("Accept", true) or frame:FindFirstChild("Confirm", true)
            local hasSlots = frame:FindFirstChild("Slot", true) or frame:FindFirstChild("Item", true)
            if hasAcceptButton and hasSlots then
                log("Found trade UI by structure: " .. frame.Name)
                return frame
            end
        end
    end
    
    return nil
end

local function getFirstItemSlot(tradeUI)
    local possibleNames = {"Slot", "Item", "Offer", "ItemSlot", "YourOffer"}
    
    for _, name in ipairs(possibleNames) do
        local slot = tradeUI:FindFirstChild(name, true)
        if slot and (slot:IsA("Frame") or slot:IsA("ImageLabel")) then
            log("Found item slot: " .. slot:GetFullName())
            return slot
        end
    end
    
    for _, child in ipairs(tradeUI:GetDescendants()) do
        if child:IsA("Frame") and #child:GetChildren() > 0 then
            for _, subChild in ipairs(child:GetChildren()) do
                if subChild:IsA("ImageLabel") then
                    log("Found item slot by structure: " .. child:GetFullName())
                    return child
                end
            end
        end
    end
    
    return nil
end

local function createFakeVisuals(originalSlot)
    log("Creating enhanced visuals on top of: " .. originalSlot:GetFullName())
    
    local originalVisible = originalSlot.Visible
    local originalTransparency = originalSlot.BackgroundTransparency
    
    local fakeLayer = Instance.new("Frame")
    fakeLayer.Name = "VisualFakeLayer" -- تم التعديل
    fakeLayer.Size = UDim2.new(1, 0, 1, 0)
    fakeLayer.Position = UDim2.new(0, 0, 0, 0)
    fakeLayer.BackgroundTransparency = 1
    fakeLayer.ZIndex = originalSlot.ZIndex + 10
    fakeLayer.Parent = originalSlot
    
    local fakeImage = Instance.new("ImageLabel")
    fakeImage.Name = "FakeItemImage"
    fakeImage.Size = UDim2.new(0.8, 0, 0.8, 0)
    fakeImage.Position = UDim2.new(0.1, 0, 0.1, 0)
    fakeImage.BackgroundTransparency = 0
    fakeImage.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    fakeImage.Image = Config.FakeImageId
    fakeImage.ScaleType = Enum.ScaleType.Fit
    fakeImage.Parent = fakeLayer
    
    local fakeLabel = Instance.new("TextLabel")
    fakeLabel.Name = "FakeItemName"
    fakeLabel.Size = UDim2.new(1, 0, 0.2, 0)
    fakeLabel.Position = UDim2.new(0, 0, 0.8, 0)
    fakeLabel.BackgroundTransparency = 1
    fakeLabel.Text = Config.TargetItemName
    fakeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    fakeLabel.TextScaled = true
    fakeLabel.Font = Enum.Font.SourceSansBold
    fakeLabel.Parent = fakeLayer
    
    local multiplierLabel = Instance.new("TextLabel")
    multiplierLabel.Name = "FakeMultiplier"
    multiplierLabel.Size = UDim2.new(0.5, 0, 0.2, 0)
    multiplierLabel.Position = UDim2.new(0.5, 0, 0, 0)
    multiplierLabel.BackgroundTransparency = 0.5
    multiplierLabel.BackgroundColor3 = Color3.fromRGB(255, 0, 255)
    multiplierLabel.Text = Config.FakeMultiplierText
    multiplierLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    multiplierLabel.TextScaled = true
    multiplierLabel.Font = Enum.Font.SourceSansBold
    fakeLayer.Parent = fakeLayer
    
    originalSlot.Visible = false
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if fakeLayer and fakeLayer.Parent then
            fakeLayer.ZIndex = 1000
        else
            if connection then
                connection:Disconnect()
            end
        end
    end)
    
    log("Enhanced visuals created successfully.")
    return fakeLayer, connection
end

local function executeVisualDeception()
    log("Starting visual enhancement process...")
    
    local tradeUI = findTradeUI()
    if not tradeUI then
        log("Trade UI not found. Retrying...")
        return
    end
    
    local itemSlot = getFirstItemSlot(tradeUI)
    if not itemSlot then
        log("Item slot not found inside the trade UI.")
        return
    end
    
    if itemSlot:FindFirstChild("VisualFakeLayer") then -- تم التعديل
        log("Enhanced layer already exists. Aborting.")
        return
    end
    
    createFakeVisuals(itemSlot)
    log("Visual enhancement applied successfully.")
end

local function monitorForTrade()
    log("Starting trade monitor loop.")
    
    while Config.Enabled do
        wait(1.5)
        
        if not Config.Enabled then
            log("Script disabled. Stopping monitor.")
            break
        end
        
        log("Checking for trade window...")
        executeVisualDeception()
    end
end

