-- Advanced Remote Scanner
local function scanForRemotes()
    local remotes = {}
    
    -- Scan all services for remotes
    for _, service in pairs({ReplicatedStorage, Workspace, game:GetService("Lighting"), game:GetService("ServerScriptService")}) do
        for _, obj in pairs(service:GetDescendants()) do
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                local name = obj.Name:lower()
                
                -- Trade related remotes
                if string.find(name, "trade") or string.find(name, "exchange") or 
                   string.find(name, "offer") or string.find(name, "deal") then
                    table.insert(remotes, {remote = obj, type = "trade"})
                end
                
                -- Inventory/Item related remotes
                if string.find(name, "item") or string.find(name, "inventory") or 
                   string.find(name, "add") or string.find(name, "give") or
                   string.find(name, "spawn") or string.find(name, "brainrot") then
                    table.insert(remotes, {remote = obj, type = "item"})
                end
            end
        end
    end
    
    return remotes
end

