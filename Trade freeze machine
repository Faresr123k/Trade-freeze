-- دالة إرسال طلب التداول المحسّن
function sendTradeRequest(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    local now = tick()
    if Config.AntiKickProtection and now - lastRequestTime < 60 / Config.MaxRequestsPerMinute then
        return false
    end

    -- استخدام الـ remote الناجح أولاً
    if successfulRemote then
        local r = ReplicatedStorage:FindFirstChild(successfulRemote, true)
        if r and r:IsA("RemoteEvent") then
            pcall(function()
                r:FireServer(targetPlayer)
                requestCount += 1
                lastRequestTime = now
                print("✅ تم إرسال طلب تداول إلى: " .. targetPlayer.Name)
            end)
            return true
        end
    end

    -- محاولات متعددة مع بيانات إضافية
    local attempts = {
        function(r) r:FireServer(targetPlayer) end,
        function(r) r:FireServer(targetPlayer, "request") end,
        function(r) r:FireServer("request", targetPlayer) end,
        function(r) r:FireServer({player = targetPlayer, type = "trade"}) end,
        function(r) r:FireServer({Target = targetPlayer, Action = "TradeRequest", Force = true}) end,
        function(r) r:FireServer({target = targetPlayer, autoAccept = true}) end
    }

    for _, path in ipairs(detectedRemotes) do
        local remote = ReplicatedStorage:FindFirstChild(path, true)
        if remote and remote:IsA("RemoteEvent") then
            for _, attempt in ipairs(attempts) do
                pcall(function()
                    attempt(remote)
                    successfulRemote = path
                    requestCount += 1
                    lastRequestTime = now
                    print("🎯 نجاح عبر: " .. path)
                end)
            end
            return true
        end
    end

    return false
end

-- دالة تجميد التداول
function freezeTrade(tradeId)
    if not Config.FreezeTrade then return false end
    
    frozenTrades[tradeId] = true
    
    -- منع الإلغاء
    if Config.BlockCancellation then
        spawn(function()
            while frozenTrades[tradeId] do
                task.wait(0.1)
                -- حظر أي محاولة إلغاء
                pcall(function()
                    for _, remote in ipairs(detectedRemotes) do
                        local r = ReplicatedStorage:FindFirstChild(remote, true)
                        if r and r:IsA("RemoteEvent") then
                            r:FireServer({action = "blockCancel", tradeId = tradeId})
                        end
                    end
                end)
            end
        end)
    end
    
    return true
end
