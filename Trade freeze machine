-- دالة التعرف على الـ brainrot (مع دعم الإضافات)
function isTargetBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    local lowerItem = string.lower(itemName)
    for _, b in ipairs(TargetBrainrots) do
        local lb = string.lower(b)
        if string.find(lowerItem, lb, 1, true) or string.find(lb, lowerItem, 1, true) then
            return true
        end
    end
    return false
end

function isPriority(name)
    if not name or type(name) ~= "string" then return false end
    local lower = string.lower(name)
    for _, b in ipairs(PriorityMoneyBrainrots) do
        local lb = string.lower(b)
        if string.find(lower, lb, 1, true) or string.find(lb, lower, 1, true) then
            return true
        end
    end
    return false
end

function trySendTradeRequest(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    local now = tick()
    if Config.AntiKickProtection and now - lastRequestTime < 60 / Config.MaxRequestsPerMinute then
        if Config.DebugMode then print("🛡️ منع إرسال لتجنب السبام") end
        return false
    end

    -- محاولة الـ remote الناجح أولاً
    if successfulRemote then
        local r = ReplicatedStorage:FindFirstChild(successfulRemote, true)
        if r and r:IsA("RemoteEvent") then
            pcall(function()
                r:FireServer(targetPlayer)
                requestCount += 1
                lastRequestTime = now
                print("استخدم الـ remote الناجح: " .. successfulRemote)
            end)
            return true
        end
    end

    -- محاولات متعددة
    local attempts = {
        function(r) r:FireServer(targetPlayer) end,
        function(r) r:FireServer(targetPlayer, "request") end,
        function(r) r:FireServer("request", targetPlayer) end,
        function(r) r:FireServer({player = targetPlayer}) end,
        function(r) r:FireServer({Target = targetPlayer, Type = "TradeRequest"}) end
    }

    for _, path in ipairs(detectedRemotes) do
        local remote = ReplicatedStorage:FindFirstChild(path, true)
        if remote and remote:IsA("RemoteEvent") then
            for _, attempt in ipairs(attempts) do
                pcall(function()
                    attempt(remote)
                    successfulRemote = path
                    requestCount += 1
                    lastRequestTime = now
                    print("نجاح محتمل عبر: " .. path)
                end)
            end
            return true
        end
    end

    warn("⚠️ لم يتم العثور على remote مناسب")
    return false
end

function scanPlayer(player)
    if player == LocalPlayer or not player.Character then return nil end
    local found, prio = nil, false

    if player.Backpack then
        for _, item in ipairs(player.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                prio = isPriority(item.Name)
                break
            end
        end
    end

    if not found and player.Character then
        for _, item in ipairs(player.Character:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                prio = isPriority(item.Name)
                break
            end
        end
    end

    return found and {name = found, priority = prio, player = player}
end

RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    local now = tick()
    if now - lastScanTime < Config.ScanInterval then return end
    lastScanTime = now

    local hrp = LocalPlayer.Character.HumanoidRootPart
    local targets, prios = {}, {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude
            if dist <= Config.MaxDistance then
                local res = scanPlayer(plr)
                if res then
                    if res.priority then table.insert(prios, res) else table.insert(targets, res) end
                end
            end
        end
    end

    PriorityCount = #prios

    if Config.AutoSendRequest then
        local list = #prios > 0 and prios or targets
        for _, t in ipairs(list) do
            if trySendTradeRequest(t.player) then
                task.wait(0.8)
                break
            end
        end
    end
end)

