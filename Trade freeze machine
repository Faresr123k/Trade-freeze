-- دالة محسّنة للتعرف على الإضافات (Gold/Diamond/Divine)
function isTargetBrainrot(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    
    local lowerItem = string.lower(itemName)
    
    -- التحقق من الإضافات المميزة أولاً
    local hasSpecialRarity = false
    if string.find(lowerItem, "gold") or string.find(lowerItem, "diamond") or 
       string.find(lowerItem, "divine") or string.find(lowerItem, "rainbow") or
       string.find(lowerItem, "mythic") or string.find(lowerItem, "legendary") then
        hasSpecialRarity = true
    end
    
    -- التحقق من اسم الـ brainrot الأساسي
    for _, brainrot in ipairs(TargetBrainrots) do
        local lowerBrain = string.lower(brainrot)
        if string.find(lowerItem, lowerBrain, 1, true) or string.find(lowerBrain, lowerItem, 1, true) then
            return true
        end
    end
    
    -- إذا كان يحتوي على إضافة مميزة، تحقق إذا كان يحتوي على أي اسم من قائمة الأساسية
    if hasSpecialRarity then
        for _, brainrot in ipairs(TargetBrainrots) do
            local lowerBrain = string.lower(brainrot)
            -- تجزئة اسم العنصر للبحث عن أجزاء من اسم الـ brainrot
            local parts = string.split(lowerItem, " ")
            for _, part in ipairs(parts) do
                if string.len(part) > 3 and string.find(lowerBrain, part, 1, true) then
                    return true
                end
            end
        end
    end
    
    return false
end

-- دالة محسّنة للتحقق من الأولوية مع دعم الإضافات
function isPriority(itemName)
    if not itemName or type(itemName) ~= "string" then return false end
    
    local lowerItem = string.lower(itemName)
    
    -- التحقق من الإضافات المميزة
    local hasSpecialRarity = false
    if string.find(lowerItem, "gold") or string.find(lowerItem, "diamond") or 
       string.find(lowerItem, "divine") or string.find(lowerItem, "rainbow") or
       string.find(lowerItem, "mythic") or string.find(lowerItem, "legendary") then
        hasSpecialRarity = true
    end
    
    -- إذا كان يحتوي على إضافة مميزة واسم أولوي، فهو أولوية
    if hasSpecialRarity then
        for _, brainrot in ipairs(PriorityMoneyBrainrots) do
            local lowerBrain = string.lower(brainrot)
            -- تجزئة اسم العنصر للبحث عن أجزاء من اسم الـ brainrot
            local parts = string.split(lowerItem, " ")
            for _, part in ipairs(parts) do
                if string.len(part) > 3 and string.find(lowerBrain, part, 1, true) then
                    return true
                end
            end
        end
    end
    
    -- التحقق من المطابقة المباشرة
    for _, brainrot in ipairs(PriorityMoneyBrainrots) do
        local lowerBrain = string.lower(brainrot)
        if string.find(lowerItem, lowerBrain, 1, true) or string.find(lowerBrain, lowerItem, 1, true) then
            return true
        end
    end
    
    return false
end

-- إرسال طلب التريد مع محاولات متعددة وحماية من السبام
function trySendTradeRequest(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return false end
    
    -- حماية من السبام
    local now = tick()
    if Config.AntiKickProtection and now - lastRequestTime < 60 / Config.MaxRequestsPerMinute then
        if Config.DebugMode then
            print("🛡️ تم منع الإرسال لتجنب السبام")
        end
        return false
    end
    
    -- استخدام الـ remote الناجح إذا تم العثور عليه مسبقًا
    if successfulRemote then
        pcall(function()
            local remote = ReplicatedStorage:FindFirstChild(successfulRemote, true)
            if remote and remote:IsA("RemoteEvent") then
                remote:FireServer(targetPlayer)
                requestCount = requestCount + 1
                lastRequestTime = now
                if Config.DebugMode then
                    print("💬 تم إرسال طلب تريد إلى " .. targetPlayer.Name .. " عبر الـ remote الناجح")
                end
                return true
            end
        end)
    end
    
    -- محاولة إرسال طلب التريد عبر الـ remotes المكتشفة
    for _, remotePath in ipairs(detectedRemotes) do
        local remote = ReplicatedStorage:FindFirstChild(remotePath, true)
        if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
            pcall(function()
                -- محاولات مختلفة للـ arguments
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(targetPlayer)                  -- محاولة 1: بسيطة
                    remote:FireServer(targetPlayer, "request")       -- محاولة 2
                    remote:FireServer("request", targetPlayer)       -- محاولة 3
                    remote:FireServer({player = targetPlayer})       -- محاولة 4: جدول
                    remote:FireServer({Target = targetPlayer, Type = "TradeRequest"}) -- محاولة 5
                end
                
                if Config.DebugMode then
                    print("💬 محاولة إرسال طلب تريد إلى " .. targetPlayer.Name .. " عبر: " .. remote:GetFullName())
                end
                
                -- حفظ الـ remote الناجح
                successfulRemote = remotePath
                requestCount = requestCount + 1
                lastRequestTime = now
                
                return true  -- توقف بعد أول محاولة ناجحة محتملة
            end)
        end
    end
    
    -- محاولة إرسال طلب التريد عبر قائمة الـ remotes المحتملة
    if #detectedRemotes == 0 then
        for _, name in ipairs(PossibleTradeRemotes) do
            local remote = ReplicatedStorage:FindFirstChild(name, true)
            if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                pcall(function()
                    if remote:IsA("RemoteEvent") then
                        remote:FireServer(targetPlayer)
                        remote:FireServer(targetPlayer, "request")
                        remote:FireServer("request", targetPlayer)
                    end
                    
                    if Config.DebugMode then
                        print("💬 محاولة إرسال طلب تريد إلى " .. targetPlayer.Name .. " عبر: " .. remote:GetFullName())
                    end
                    
                    -- حفظ الـ remote الناجح
                    successfulRemote = name
                    requestCount = requestCount + 1
                    lastRequestTime = now
                    
                    return true
                end)
            end
        end
    end
    
    if Config.DebugMode then
        warn("⚠️ لم يتم العثور على Remote مناسب للتريد")
    end
    return false
end

-- دالة المسح مع تحسينات
function scanPlayer(player)
    if player == LocalPlayer or not player.Character then return nil end
    local found, prio = nil, false

    -- فحص الـ backpack أولاً
    if player.Backpack then
        for _, item in ipairs(player.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                prio = isPriority(item.Name)
                break
            end
        end
    end

    -- فحص الـ character إذا لم يتم العثور على شيء في الـ backpack
    if not found and player.Character then
        for _, item in ipairs(player.Character:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                prio = isPriority(item.Name)
                break
            end
        end
    end

    return found and {name = found, priority = prio, player = player}
end

-- الحلقة الرئيسية مع تحسينات
RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    local now = tick()
    if now - lastScanTime < Config.ScanInterval then return end
    lastScanTime = now

    local hrp = LocalPlayer.Character.HumanoidRootPart
    local targets, prios = {}, {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude
            if dist <= Config.MaxDistance then
                local res = scanPlayer(plr)
                if res then
                    if res.priority then
                        table.insert(prios, res)
                    else
                        table.insert(targets, res)
                    end
                end
            end
        end
    end

    PriorityCount = #prios

    if Config.AutoSendRequest then
        local list = #prios > 0 and prios or targets
        for _, t in ipairs(list) do
            if trySendTradeRequest(t.player) then
                task.wait(0.8)  -- تأخير لتجنب spam
                break
            end
        end
    end
end)

