local function update()
    status.Text = Config.Enabled and "Status: Active" or "Status: Inactive"
    status.TextColor3 = Config.Enabled and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 80, 80)
    
    freezeBtn.Text = Config.FreezeTrade and "❄️ Freeze: ON" or "❄️ Freeze: OFF"
    freezeBtn.BackgroundColor3 = Config.FreezeTrade and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(100, 100, 100)
    
    acceptBtn.Text = Config.AutoAccept and "🔒 Accept: ON" or "🔒 Accept: OFF"
    acceptBtn.BackgroundColor3 = Config.AutoAccept and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(100, 100, 100)
    
    mainBtn.Text = Config.Enabled and "🔴 Disable" or "🟢 Enable"
    mainBtn.BackgroundColor3 = Config.Enabled and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(0, 200, 0)
end

-- الأحداث
