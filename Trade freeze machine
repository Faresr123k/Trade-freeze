-- نظام مراقبة وتحسين الأداء
spawn(function()
    local performanceData = {
        successfulTrades = 0,
        failedTrades = 0,
        averageResponseTime = 0,
        lastActivity = tick()
    }
    
    while task.wait(5) do
        if Config.Enabled then
            -- تحليل الأداء
            local currentTime = tick()
            local timeDiff = currentTime - performanceData.lastActivity
            
            if timeDiff > 60 then
                -- إعادة تفعيل إذا كان خاملاً لفترة طويلة
                print("🔄 إعادة تفعيل النظام بعد فترة خمول")
                performanceData.lastActivity = currentTime
            end
            
            -- تنظيف التداولات القديمة
            local tradesToRemove = {}
            for tradeId, timestamp in pairs(frozenTrades) do
                if currentTime - timestamp > 300 then -- 5 دقائق
                    table.insert(tradesToRemove, tradeId)
                end
            end
            
            for _, tradeId in ipairs(tradesToRemove) do
                frozenTrades[tradeId] = nil
            end
        end
    end
end)

-- نظام استجابة سريع للـ Remotes
spawn(function()
    -- الاستماع لجميع الـ Remotes المكتشفة
    for _, path in ipairs(detectedRemotes) do
        local remote = ReplicatedStorage:FindFirstChild(path, true)
        if remote and remote:IsA("RemoteEvent") then
            remote.OnClientEvent:Connect(function(...)
                local args = {...}
                
                -- تحقق من رسائل التداول
                if Config.Enabled then
                    for i, arg in ipairs(args) do
                        if type(arg) == "table" then
                            -- البحث عن معرف التداول
                            if arg.tradeId or arg.TradeId or arg.id then
                                local tradeId = arg.tradeId or arg.TradeId or arg.id
                                
                                -- تجميد فوري
                                if Config.FreezeTrade then
                                    freezeTrade(tradeId)
                                end
                                
                                -- قبول تلقائي
                                if Config.ForceAcceptTrades then
                                    task.wait(0.3)
                                    autoAcceptTrade(tradeId)
                                end
                                
                                print("🎯 تم اكتشاف تداول جديد: " .. tostring(tradeId))
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- نظام تحسين ديناميكي
spawn(function()
    local optimizationInterval = 30 -- ثانية
    
    while task.wait(optimizationInterval) do
        if Config.Enabled then
            -- تحسين المسح حسب عدد اللاعبين
            local playerCount = #Players:GetPlayers()
            
            if playerCount > 20 then
                Config.ScanInterval = 2.0 -- تبطيء المسح في السيرفرات المزدحمة
            elseif playerCount > 10 then
                Config.ScanInterval = 1.5
            else
                Config.ScanInterval = 1.0 -- تسريع المسح في السيرفرات الفارغة
            end
            
            -- تحسين عدد الطلبات حسب الأداء
            if requestCount > 50 and tick() - lastRequestTime < 60 then
                Config.MaxRequestsPerMinute = 15 -- تقليل الطلبات لتجنب الحظر
            elseif requestCount < 10 then
                Config.MaxRequestsPerMinute = 30 -- زيادة الطلبات عند الأداء الجيد
            end
            
            if Config.DebugMode then
                print("⚙️ تم تحسين الإعدادات - المسح: " .. Config.ScanInterval .. "s | الطلبات: " .. Config.MaxRequestsPerMinute .. "/min")
            end
        end
    end
end)

-- نظام تسجيل الأحداث
spawn(function()
    local eventLog = {}
    local maxLogSize = 50
    
    local function logEvent(eventType, details)
        local timestamp = os.date("%H:%M:%S")
        table.insert(eventLog, 1, {
            time = timestamp,
            type = eventType,
            details = details
        })
        
        -- الحفاظ على حجم السجل
        while #eventLog > maxLogSize do
            table.remove(eventLog, #eventLog)
        end
        
        if Config.DebugMode then
            print("[" .. timestamp .. "] " .. eventType .. ": " .. details)
        end
    end
    
    -- تسجيل الأحداث المهمة
    while task.wait(1) do
        if Config.Enabled then
            -- مراقبة التغييرات
            if requestCount > 0 and requestCount % 10 == 0 then
                logEvent("MILESTONE", "تم إرسال " .. requestCount .. " طلب")
            end
            
            local count = 0
for _ in pairs(frozenTrades) do count += 1 end
if count > 0 and count % 5 == 0 then
                logEvent("FREEZE", "تم تجميد " .. #frozenTrades .. " تداول")
            end
        end
    end
end)

-- نظام حماية إضافي
spawn(function()
    local protectionInterval = 10 -- ثانية
    
    while task.wait(protectionInterval) do
        if Config.Enabled and Config.AntiKickProtection then
            -- إرسال إشارات حياة مختلفة
            pcall(function()
                -- إشارة الحركة
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    -- محاكاة نشاط اللاعب
                    local hrp = LocalPlayer.Character.HumanoidRootPart
                    local randomOffset = Vector3.new(
                        math.random(-0.1, 0.1),
                        0,
                        math.random(-0.1, 0.1)
                    )
                    
                    -- لا نغير الموقع الفعلي، نرسب فقط إشارات
                    for _, remote in ipairs(detectedRemotes) do
                        local r = ReplicatedStorage:FindFirstChild(remote, true)
                        if r and r:IsA("RemoteEvent") then
                            r:FireServer({
                                activity = "movement",
                                position = hrp.Position + randomOffset,
                                timestamp = tick()
                            })
                        end
                    end
                end
            end)
        end
    end
end)

